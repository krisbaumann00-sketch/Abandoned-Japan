# Abandoned Japan — Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Backend ───────────────────────────────────────────────────────────────────
# URL of your local FastAPI backend (default: http://127.0.0.1:8000)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# ─── Google Maps ───────────────────────────────────────────────────────────────
# Required for the interactive map and Street View sections
# Get an API key at: https://console.cloud.google.com/
# Enable: Maps Embed API, Maps JavaScript API, Street View API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Auth (next-auth) ──────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=your_nextauth_secret_here

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
